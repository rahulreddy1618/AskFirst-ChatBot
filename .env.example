# ── LLM Provider ────────────────────────────────────────────────────────────────
# Choose "groq" (free, fast) or "openai"
LLM_PROVIDER=groq

# ── Groq (default) ──────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI (alternative) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── Model ────────────────────────────────────────────────────────────────────────
# Groq options : llama-3.3-70b-versatile | mixtral-8x7b-32768 | llama3-8b-8192
# OpenAI options: gpt-4o | gpt-4o-mini | gpt-3.5-turbo
LLM_MODEL=llama-3.3-70b-versatile

# ── Streamlit → Backend URL ──────────────────────────────────────────────────────
API_URL=http://localhost:8000
